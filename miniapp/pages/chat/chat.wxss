.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 头部 */
.header {
  padding: 32rpx 40rpx 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
  background: #fff;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}
.subtitle {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  display: block;
}

/* 聊天区 */
.chat-area {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.welcome {
  text-align: center;
  padding-top: 120rpx;
}
.welcome-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.welcome-text { font-size: 32rpx; font-weight: 600; color: #1f2937; display: block; }
.welcome-desc { font-size: 26rpx; color: #9ca3af; margin-top: 8rpx; display: block; }

.presets {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 40rpx;
  gap: 16rpx;
}
.preset {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #2563eb;
}

/* 消息 */
.msg { margin-bottom: 24rpx; display: flex; }
.msg-user { justify-content: flex-end; }
.msg-ai { justify-content: flex-start; }

.bubble {
  max-width: 82%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}
.bubble-user {
  background: #2563eb;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}
.bubble-ai {
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-bottom-left-radius: 6rpx;
}

.text { color: #1f2937; }
.bubble-user .text { color: #fff; }

.source {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e5e7eb;
  font-size: 22rpx;
  color: #9ca3af;
}

/* 思考中动画 */
.thinking { display: flex; gap: 10rpx; padding: 8rpx 0; }
.dot {
  width: 12rpx; height: 12rpx;
  background: #93c5fd;
  border-radius: 50%;
  animation: bounce 1.4s infinite both;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 业务卡片 */
.cards { margin-top: 16rpx; display: flex; flex-direction: column; gap: 12rpx; }
.card {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
}
.card-action { background: #eff6ff; border-color: #2563eb; }
.card-info { background: #f8fafc; }
.card-alert { background: #fef2f2; border-color: #ef4444; }
.card-title { font-size: 26rpx; font-weight: 600; color: #1f2937; }
.card-desc { font-size: 22rpx; color: #6b7280; margin-top: 4rpx; }
.card-btn {
  margin-top: 12rpx;
  background: #2563eb;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 输入区 */
.input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5e7eb;
  background: #fff;
}
.input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f3f4f6;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #2563eb;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  text-align: center;
  padding: 0;
}
