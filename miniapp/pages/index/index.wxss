.container { display:flex; flex-direction:column; height:100vh; background:#f8f9ff; }
.chat-list { flex:1; padding:16px; }
.msg-row { margin-bottom:16px; display:flex; }
.msg-right { justify-content:flex-end; }
.msg-left { flex-direction:row; align-items:flex-start; }
.msg-avatar { font-size:32px; margin-right:8px; }
.msg-content { max-width:80%; }
.msg-bubble { padding:10px 14px; border-radius:14px; font-size:15px; line-height:1.6; }
.msg-user { background:#004ac6; color:#fff; border-bottom-right-radius:4px; }
.msg-ai { background:#fff; border:1px solid #c3c6d7; border-left:4px solid #712ae2; border-bottom-left-radius:4px; }
.msg-source { font-size:12px; color:#737686; margin-top:4px; }
.card-list { margin-top:8px; }
.card { background:#e5eeff; border:1px solid #004ac6; border-radius:12px; padding:12px; margin-bottom:8px; }
.card-title { font-size:14px; font-weight:600; }
.card-desc { font-size:12px; color:#737686; margin:4px 0; }
.card-btn { background:#004ac6; color:#fff; border-radius:8px; font-size:12px; }
.input-area { display:flex; padding:12px; background:#fff; border-top:1px solid #c3c6d7; }
.input-box { flex:1; height:40px; background:#eff4ff; border-radius:20px; padding:0 16px; font-size:14px; }
.send-btn { margin-left:8px; background:#004ac6; color:#fff; border-radius:20px; font-size:14px; padding:0 20px; }
